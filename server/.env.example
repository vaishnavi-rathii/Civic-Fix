# Database
DATABASE_URL="postgresql://user:password@localhost:5432/civicfix"

# JWT
JWT_ACCESS_SECRET="your-access-secret-min-32-chars-change-this"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars-change-this"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Email (use Gmail App Password or SMTP provider)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="CivicFix <noreply@civicfix.in>"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# App
PORT=5000
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:admin@civicfix.in"
